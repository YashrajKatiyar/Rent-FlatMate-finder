# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/rent-flatmate-finder

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Anthropic (Claude) API — used for AI compatibility scoring
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Email (Nodemailer) — Gmail example using an App Password (free tier)
EMAIL_SERVICE=gmail
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="Rent & Flatmate Finder <youraddress@gmail.com>"

# Compatibility score threshold that triggers "high match" owner email
HIGH_MATCH_THRESHOLD=80
